# ==========================================================
# Sentry configuration
# ==========================================================
# Paste the DSN for the Sentry project you want telemetry to land in.
SENTRY_DSN=https://<public_key>@<ingest_host>/<project_id>

# Used by the traffic simulator (scripts/simulate.ts). Usually the same DSN.
SENTRY_DSN_SIMULATOR=

# Source map upload (optional — only needed if you want code frames resolved).
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=

# Release tag — every span will carry this as `app.release`.
SENTRY_RELEASE=marketplace-web@2026.04.16-demo

# Environment — every span will carry this as `app.environment`.
SENTRY_ENVIRONMENT=demo

# ---------- Simulator tuning ----------
# How many synthetic users to run concurrently.
SIM_CONCURRENCY=8
# Duration in seconds; 0 = run forever.
SIM_DURATION_SEC=0
# Seed for deterministic runs (optional).
SIM_SEED=
